<?xml version="1.0" encoding="utf-8"?>
<!--
  Multi-page weather widget. Same default cell size as the regular
  weather widget but always 4x2 (smaller layouts don't fit the page
  nav bar comfortably).
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="280dp"
    android:minHeight="110dp"
    android:minResizeWidth="280dp"
    android:minResizeHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_preview"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewLayout="@layout/widget_preview"
    android:description="@string/widget_multi_description" />
